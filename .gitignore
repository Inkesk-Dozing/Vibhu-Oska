# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Virtual Environment ──
.venv/
venv/
ENV/

# ── IDE ──
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── Environment & Secrets ──
.env
.env.local
.env.production
*.pem
*.key

# ── Data & Models (large files) ──
Data/chromadb/
Data/training/
Data/weights/
Models/router/checkpoints/
Models/reasoning/adapters/

# ── Logs ──
Log/*.log

# ── Docker ──
docker-compose.override.yml

# ── OS Files ──
.DS_Store
Thumbs.db
desktop.ini

# ── Generated Protobuf Bindings ──
Shared/generated/

# ── Testing ──
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# ── Misc ──
*.bak
*.tmp

recovered_chat_history.md
